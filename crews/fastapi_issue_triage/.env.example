# ------------------------------------------------------------------------------
# FastAPI Issue Triage Crew environment template
# Copy this file to `.env` in the same folder and fill real values.
# ------------------------------------------------------------------------------

# Required for stable GitHub API access and higher rate limits
GITHUB_TOKEN=ghp_replace_with_real_token

# Optional: override default repository target
# Default: tiangolo/fastapi (the code resolves to fastapi/fastapi automatically)
FASTAPI_TARGET_REPO=tiangolo/fastapi

# Optional: default issue reference if CLI arg is omitted
# Examples: 14680 OR fastapi/fastapi#14680 OR https://github.com/fastapi/fastapi/issues/14680
FASTAPI_ISSUE_REF=

# Optional: related issue search (extra GitHub API usage)
# 0 = disabled (recommended), 1 = enabled
FASTAPI_ENABLE_RELATED_SEARCH=0

# ------------------------------------------------------------------------------
# Optional LLM enhancement mode
# If unset, crew runs deterministic triage only.
# ------------------------------------------------------------------------------

# Option A: use provider-specific keys directly
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Option B: agentforge custom provider settings
# agentforge_LLM_PROVIDER=custom
# agentforge_LLM_MODEL=gpt-4o-mini
# agentforge_LLM_API_KEY=
# agentforge_LLM_BASE_URL=https://api.openai.com/v1

# Option C: local model providers
# agentforge_LLM_PROVIDER=ollama
# agentforge_LLM_MODEL=ollama/llama3.2:latest
# agentforge_LLM_BASE_URL=http://localhost:11434
